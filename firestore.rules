rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin (you can customize this based on your auth system)
    function isAdmin() {
      return isAuthenticated(); // For now, any authenticated user can write
      // In production, you might want: return request.auth.token.admin == true;
    }
    
    // Helper function to validate track data
    function isValidTrackData() {
      return request.resource.data.title is string &&
             request.resource.data.title.size() > 0 &&
             request.resource.data.artist is string &&
             request.resource.data.artist.size() > 0 &&
             request.resource.data.genre is string &&
             request.resource.data.genre.size() > 0 &&
             request.resource.data.status in ['published', 'draft'];
    }
    
    // Helper function to validate artist data
    function isValidArtistData() {
      return request.resource.data.name is string &&
             request.resource.data.name.size() > 0 &&
             request.resource.data.status in ['active', 'inactive'];
    }
    
    // Helper function to validate payment data
    function isValidPaymentData() {
      return request.resource.data.fullName is string &&
             request.resource.data.fullName.size() > 0 &&
             request.resource.data.amount is number &&
             request.resource.data.amount > 0 &&
             request.resource.data.billingCycle in ['weekly', 'monthly', 'yearly'] &&
             request.resource.data.status in ['pending', 'completed', 'failed'];
    }
    
    // Helper function to validate settings data
    function isValidSettingsData() {
      return true; // Allow flexible settings structure for now
    }
    
    // Artists collection
    match /artists/{artistId} {
      // Public read access for music page
      allow read: if true;
      
      // Write access (TEMPORARY: disabled auth for development)
      allow create: if true;
      allow update: if true;
      allow delete: if true;
      
      // In production, use:
      // allow create: if isAdmin() && isValidArtistData();
      // allow update: if isAdmin() && isValidArtistData();
      // allow delete: if isAdmin();
    }
    
    // Tracks collection
    match /tracks/{trackId} {
      // Public read access for music page (only published tracks)
      allow read: if resource.data.status == 'published' || true;
      
      // Write access (TEMPORARY: disabled auth for development)
      allow create: if true;
      allow update: if true;
      allow delete: if true;
      
      // In production, use:
      // allow create: if isAdmin() && isValidTrackData();
      // allow update: if isAdmin() && isValidTrackData();
      // allow delete: if isAdmin();
    }
    
    // Payments collection
    match /payments/{paymentId} {
      // Admin read access for dashboard
      allow read: if true;
      
      // Write access (TEMPORARY: disabled auth for development)
      allow create: if true;
      allow update: if true;
      allow delete: if true;
      
      // In production, use:
      // allow read: if isAdmin();
      // allow create: if isAdmin() && isValidPaymentData();
      // allow update: if isAdmin();
      // allow delete: if isAdmin();
    }
    
    // Allow list queries for all collections
    match /artists/{artistId} {
      allow list: if true;
    }
    
    match /tracks/{trackId} {
      allow list: if true;
    }
    
    match /payments/{paymentId} {
      allow list: if true;
    }
    
    // Settings collection - public read, admin write
    match /settings/{document=**} {
      // Public read access for config (prices, payment details)
      allow read: if true;
      
      // Write access for admin only (TEMPORARY: disabled auth for development)
      allow write: if true;
      
      // In production, use:
      // allow write: if isAdmin() && isValidSettingsData();
    }
  }
}
