rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is super admin (by email whitelist)
    function isSuperAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == 'barasagodwil@gmail.com';
    }
    
    // Helper function to check if user is admin (Firestore allowlist or super admin)
    function isAdmin() {
      return isSuperAdmin() || 
             (isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }
    
    // Helper function to validate track data
    function isValidTrackData() {
      return request.resource.data.title is string &&
             request.resource.data.title.size() > 0 &&
             request.resource.data.artist is string &&
             request.resource.data.artist.size() > 0 &&
             request.resource.data.genre is string &&
             request.resource.data.genre.size() > 0 &&
             request.resource.data.status in ['published', 'draft'];
    }
    
    // Helper function to validate artist data
    function isValidArtistData() {
      return request.resource.data.name is string &&
             request.resource.data.name.size() > 0 &&
             request.resource.data.status in ['active', 'inactive'];
    }
    
    // Helper function to validate payment data
    function isValidPaymentData() {
      return request.resource.data.userId is string &&
             request.resource.data.userId.size() > 0 &&
             request.resource.data.userEmail is string &&
             request.resource.data.userEmail.size() > 0 &&
             request.resource.data.userName is string &&
             request.resource.data.userName.size() > 0 &&
             request.resource.data.plan is string &&
             request.resource.data.plan.size() > 0 &&
             request.resource.data.amount is number &&
             request.resource.data.amount > 0 &&
             request.resource.data.paymentMethod is string &&
             request.resource.data.paymentMethod.size() > 0 &&
             request.resource.data.transactionId is string &&
             request.resource.data.transactionId.size() > 0 &&
             request.resource.data.phoneNumber is string &&
             request.resource.data.phoneNumber.size() > 0 &&
             request.resource.data.status in ['pending', 'verified', 'rejected', 'completed'];
    }
    
    // Helper function to validate settings data
    function isValidSettingsData() {
      return true; // Allow flexible settings structure
    }
    
    // Artists collection
    match /artists/{artistId} {
      // Public read access for music page
      allow read: if true;
      
      // Write access (admin only)
      allow create: if isAdmin() && isValidArtistData();
      allow update: if isAdmin() && isValidArtistData();
      allow delete: if isAdmin();
      
      // In production, use:
      // allow create: if isAdmin() && isValidArtistData();
      // allow update: if isAdmin() && isValidArtistData();
      // allow delete: if isAdmin();
      
      allow list: if true;
    }
    
    // Tracks collection
    match /tracks/{trackId} {
      // Public read access for music page (only published tracks)
      allow read: if resource.data.status == 'published' || true;
      
      // Write access (admin only)
      allow create: if isAdmin() && isValidTrackData();
      allow update: if isAdmin();
      allow delete: if isAdmin();
      
      // In production, use:
      // allow create: if isAdmin() && isValidTrackData();
      // allow update: if isAdmin() && isValidTrackData();
      // allow delete: if isAdmin();
      
      allow list: if true;
    }
    
    // Payments collection
    match /payments/{paymentId} {
      // Users can read their own payments
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Admins can read all payments
      allow read: if isAdmin();
      
      // Users can create their own payments
      allow create: if isAuthenticated() && 
                     request.resource.data.userId == request.auth.uid &&
                     isValidPaymentData();
      
      // Admins can update payment status
      allow update: if isAdmin();
      
      // Admins can delete payments
      allow delete: if isAdmin();
      
      // Admins can list all payments
      allow list: if isAdmin();
    }
    
    // User payments subcollection - users can only read their own
    match /users/{userId}/payments/{paymentId} {
      allow read: if isAuthenticated() && userId == request.auth.uid;
      allow create: if isAuthenticated() && userId == request.auth.uid && isValidPaymentData();
      allow list: if isAuthenticated() && userId == request.auth.uid;
    }
    
    // Settings collection - public read, admin write
    match /settings/{document=**} {
      // Public read access for config (prices, payment details, contact info, about stats)
      allow read: if true;
      
      // Write access for admin only
      allow write: if isAdmin() && isValidSettingsData();
      
      // In production, use:
      // allow write: if isAdmin() && isValidSettingsData();
    }

    // Users collection - each user can access only their own data
    match /users/{userId} {
      allow read: if (isAuthenticated() && userId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated() && userId == request.auth.uid;
      allow update: if (isAuthenticated() && userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();

      allow list: if isAdmin();

      // Subcollections under a user (listeningEvents, notifications, favorites, playlists, etc.)
      match /{subcollection}/{docId} {
        allow read, create, update, delete: if (isAuthenticated() && userId == request.auth.uid) || isAdmin();
      }
    }

    // Admin allowlist - only super admin can manage
    match /admins/{adminId} {
      allow read: if isSuperAdmin() || isAdmin();
      allow create, update, delete: if isSuperAdmin();
      allow list: if isSuperAdmin() || isAdmin();
    }
    
    // Team collection - public read, admin write
    match /team/{document=**} {
      // Public read access for team member info displayed on about page
      allow read: if true;
      
      // Write access for admin only
      allow write: if isAdmin();
      
      // In production, use:
      // allow write: if isAdmin() && isValidTeamData();
    }
  }
}
